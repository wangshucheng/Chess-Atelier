# 联机对战 Cloudflare Workers 后端 URL
# 1. cd worker && npm install
# 2. npx wrangler login  → 浏览器登录 Cloudflare
# 3. npx wrangler kv namespace create ROOMS  → 把返回的 id 填入 worker/wrangler.toml
# 4. cd .. && 在 worker/ 下执行 npm run deploy
# 5. 部署后获得 Worker URL（形如 https://chess-multiplayer.<account>.workers.dev）
# 6. 复制本文件为 .env.local 并填入下方变量

VITE_WORKER_URL=https://your-worker-url.example.com
